{
  "name": "slack-lite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c red,cyan \"npm:dev -w server\" \"npm:dev -w client\"",
    "build": "npm -w server run build && npm -w client run build",
    "lint": "npm -w server run lint && npm -w client run lint"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}


